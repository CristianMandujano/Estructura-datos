  <property name="styleSheet">
   <string notr="true">/* Ventana principal con fondo blanco limpio */
QMainWindow, QDialog {
    background-color: #f8f9fa;
    color: #1a1a1a;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
}

/* Etiquetas de texto grandes y bien oscuras para que las lea sin esfuerzo */
QLabel {
    color: #212529;
    font-size: 14px;
    font-weight: 500;
}

/* Título principal destacado */
QLabel#titulo {
    font-size: 22px;
    font-weight: bold;
    color: #0056b3;
    padding-bottom: 10px;
}

/* Cajas de texto blancas con bordes grises bien definidos */
QLineEdit {
    background-color: #ffffff;
    color: #212529;
    border: 2px solid #ced4da;
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 14px;
}

/* Cuando el profe dé clic en la caja de texto, el borde se vuelve azul */
QLineEdit:focus {
    border: 2px solid #0056b3;
    background-color: #ffffff;
}

/* Botones del menú en un azul rey elegante y letras blancas de alto contraste */
QPushButton {
    background-color: #0056b3;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #004085; /* Se oscurece un poco al pasar el mouse */
}

QPushButton:pressed {
    background-color: #002752; /* Más oscuro al dar clic */
}

/* Botón especial para Salir o Eliminar en un rojo que resalte bien */
QPushButton#btn_eliminar, QPushButton#btn_salir {
    background-color: #dc3545;
}

QPushButton#btn_eliminar:hover, QPushButton#btn_salir:hover {
    background-color: #bd2130;
}

/* Área de texto/consola donde se va a imprimir la Pila */
/* Fondo gris muy claro con letras negras tipo Courier, ultra legible */
QTextEdit, QPlainTextEdit {
    background-color: #ffffff;
    color: #1a1a1a;
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
    font-size: 14px;
    border: 2px solid #ced4da;
    border-radius: 6px;
    padding: 10px;
}</string>

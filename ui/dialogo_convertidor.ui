  <property name="styleSheet">
   <string notr="true">/* Estilo especial para el Label de resultado */
QLabel#lbl_resultado {
    background-color: #EDF2F7;
    color: #2B6CB0;
    border: 2px solid #CBD5E0;
    border-radius: 6px;
    padding: 8px 12px;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 15px;
    font-weight: bold;
}
/* Estilo para la Ventana Principal */
QMainWindow {
    background-color: #F8F9FA;
}

/* Estilo para etiquetas de texto (Labels) */
QLabel {
    font-family: &quot;Segoe UI&quot;, &quot;Arial&quot;, sans-serif;
    font-size: 14px;
    color: #2D3748;
    font-weight: 500;
}

/* Título del proyecto */
QLabel#lbl_titulo {
    font-size: 20px;
    color: #1A365D;
    font-weight: bold;
    margin-bottom: 10px;
}

/* Cajas de texto (Input y Output) */
QLineEdit {
    background-color: #FFFFFF;
    border: 2px solid #E2E8F0;
    border-radius: 6px;
    padding: 8px 12px;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 14px;
    color: #1A202C;
}

/* Cuando el usuario da clic en la caja de texto */
QLineEdit:focus {
    border: 2px solid #3182CE;
    background-color: #FFFFFF;
}

/* Caja de texto del resultado (Modo Solo Lectura) */
QLineEdit:read-only {
    background-color: #EDF2F7;
    color: #4A5568;
    border: 2px solid #CBD5E0;
}

/* Botón Elegante */
QPushButton {
    background-color: #3182CE;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 10px 20px;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 14px;
    font-weight: bold;
}

/* Efecto cuando el mouse pasa por encima del botón */
QPushButton:hover {
    background-color: #2B6CB0;
}

/* Efecto cuando dan clic al botón */
QPushButton:pressed {
    background-color: #2C5282;
}

/* Marcos contenedores para agrupar elementos (Opcional) */
QFrame {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 8px;
}</string>
